<?xml version="1.0"?>
<launch>
  <arg
    name="robot_prefix"
    default="crazyflie"
    description="Robot namespace/prefix used by goal follower node"/>
  <arg
    name="goal_topic"
    default="/goal_pose"
    description="PoseStamped goal topic"/>
  <arg
    name="use_takeoff"
    default="true"
    description="Take off automatically before first goal"/>
  <arg
    name="takeoff_height"
    default="0.5"
    description="Takeoff height in meters"/>
  <arg
    name="takeoff_duration_sec"
    default="2.0"
    description="Takeoff duration in seconds"/>
  <arg
    name="go_to_duration_sec"
    default="3.0"
    description="Go-to command duration in seconds"/>
  <arg
    name="land_on_shutdown"
    default="true"
    description="Attempt landing when goal follower shuts down"/>
  <arg
    name="land_height"
    default="0.0"
    description="Landing height in meters"/>
  <arg
    name="land_duration_sec"
    default="2.0"
    description="Landing duration in seconds"/>
  <arg
    name="use_sim_time"
    default="true"
    description="Use simulation time if true"/>
  <arg
    name="use_map_line_check"
    default="true"
    description="If true, reject goals with blocked Bresenham line on static map"/>
  <arg
    name="map_topic"
    default="/map"
    description="OccupancyGrid topic for static map checks"/>
  <arg
    name="occupancy_block_threshold"
    default="65"
    description="Occupancy value considered blocked"/>
  <arg
    name="treat_unknown_as_obstacle"
    default="true"
    description="Treat unknown occupancy cells as blocked"/>
  <arg
    name="enable_waypoint_publisher"
    default="false"
    description="Start waypoint publisher node when true"/>
  <arg
    name="waypoints"
    default="$(find-pkg-share crazyflie_goal_follower)/maps/waypoints.txt"
    description="Text file with waypoint rows like x, y or x, y, z"/>
  <arg
    name="waypoint_frame_id"
    default="map"
    description="Frame id for published PoseStamped goals"/>
  <arg
    name="waypoint_default_z"
    default="0.0"
    description="Default z used when CSV row has no z value"/>
  <arg
    name="waypoint_publish_period_sec"
    default="1.0"
    description="Period between publishing CSV waypoints"/>
  <arg
    name="waypoint_start_delay_sec"
    default="1.0"
    description="Delay before first waypoint publish"/>

  <include file="$(find-pkg-share ros_gz_crazyflie_bringup)/launch/crazyflie_simulation.launch.py">
    <arg name="enable_control_services" value="false"/>
  </include>
  <arg name="map_yaml" default="$(find-pkg-share crazyflie_goal_follower)/maps/greenhouse_map.yaml"/>

  <node
    pkg="crazyflie_goal_follower"
    exec="service_compat"
    name="crazyflie_service_compat"
    output="screen">
    <param name="robot_prefix" value="$(var robot_prefix)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="cmd_vel_frame" value="body"/>
    <param name="max_xy_speed" value="0.25"/>
    <param name="max_z_speed" value="0.8"/>
    <param name="max_yaw_rate" value="0.4"/>
    <param name="kp_xy" value="0.8"/>
    <param name="kp_z" value="3.0"/>
    <param name="kp_yaw" value="0.8"/>
  </node>

  <node
    pkg="crazyflie_goal_follower"
    exec="goal_follower_node"
    name="goal_follower_node"
    output="screen">
    <param name="robot_prefix" value="$(var robot_prefix)"/>
    <param name="goal_topic" value="$(var goal_topic)"/>
    <param name="use_takeoff" value="$(var use_takeoff)"/>
    <param name="takeoff_height" value="$(var takeoff_height)"/>
    <param name="takeoff_duration_sec" value="$(var takeoff_duration_sec)"/>
    <param name="go_to_duration_sec" value="$(var go_to_duration_sec)"/>
    <param name="land_on_shutdown" value="$(var land_on_shutdown)"/>
    <param name="land_height" value="$(var land_height)"/>
    <param name="land_duration_sec" value="$(var land_duration_sec)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="use_map_line_check" value="$(var use_map_line_check)"/>
    <param name="map_topic" value="$(var map_topic)"/>
    <param name="occupancy_block_threshold" value="$(var occupancy_block_threshold)"/>
    <param name="treat_unknown_as_obstacle" value="$(var treat_unknown_as_obstacle)"/>
  </node>

  <node
    if="$(var enable_waypoint_publisher)"
    pkg="crazyflie_goal_follower"
    exec="waypoint_publisher_node"
    name="waypoint_publisher_node"
    output="screen">
    <param name="goal_topic" value="$(var goal_topic)"/>
    <param name="waypoints_txt" value="$(var waypoints)"/>
    <param name="frame_id" value="$(var waypoint_frame_id)"/>
    <param name="default_z" value="$(var waypoint_default_z)"/>
    <param name="publish_period_sec" value="$(var waypoint_publish_period_sec)"/>
    <param name="start_delay_sec" value="$(var waypoint_start_delay_sec)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node
    pkg="tf2_ros"
    exec="static_transform_publisher"
    name="map_to_odom_tf"
    output="screen"
    args="0 0 0 0 0 0 map $(var robot_prefix)/odom"/>

  <node
    pkg="rviz2"
    exec="rviz2"
    name="rviz2"
    output="screen"
    args="-d $(find-pkg-share crazyflie_ros2_multiranger_bringup)/config/sim_mapping.rviz">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen">
   <param name="yaml_filename" value="$(var map_yaml)"/>
   <param name="frame_id" value="map"/>
   <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_map" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="autostart" value="true"/>
    <param name="node_names" value="['map_server']"/>
  </node>

</launch>
